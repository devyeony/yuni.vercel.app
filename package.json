{
  "name": "yuni",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check . && tsc --noEmit && node scripts/check-i18n.mjs && knip",
    "prepare": "lefthook install",
    "test": "vitest run",
    "verify": "next build && playwright test",
    "lint": "biome check",
    "format": "biome format --write",
    "setup:agents": "node scripts/setup-agents.mjs"
  },
  "dependencies": {
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "pretendard": "^1.3.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "size-limit": [
    {
      "name": "client JS (all chunks, brotli)",
      "path": ".next/static/chunks/**/*.js",
      "limit": "250 kB"
    }
  ]
}
